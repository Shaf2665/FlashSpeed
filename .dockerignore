# Version control — not needed in the build context
.git
.github

# Frontend build artifacts — rebuilt inside the Docker stages
web/node_modules
web/dist

# Local development artifacts
tmp/
graphify-out/

# Compiled binaries — rebuilt inside Docker
*.exe
flashyspeed
db.test.exe

# Database files — never bake live data into an image
*.db
*.db-shm
*.db-wal

# TLS certificates and private keys — never bake secrets into an image
tls/
*.pem
*.key

# Tool-specific directories not needed in the build
.claude/
.superpowers/

# OS files
.DS_Store
Thumbs.db
